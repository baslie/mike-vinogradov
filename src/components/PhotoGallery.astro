---
interface Props {
  images: string[];
  base: string;
}

const { images, base } = Astro.props;
---

<div class="columns-2 lg:columns-3 gap-4">
  {images.map((src, i) => (
    <button
      class="block w-full mb-4 break-inside-avoid cursor-zoom-in group animate-on-scroll"
      data-lightbox-trigger
      data-index={i}
      data-src={`${base}${src}`}
      type="button"
      style={i < 6 ? `transition-delay: ${i * 50}ms` : undefined}
    >
      <img
        src={`${base}${src}`}
        alt=""
        class="w-full rounded-[var(--radius-card)] transition-transform duration-300 group-hover:scale-[1.03]"
        loading="lazy"
        decoding="async"
      />
    </button>
  ))}
</div>
