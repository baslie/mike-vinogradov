---
import Layout from '../layouts/Layout.astro';
import BentoGrid from '../components/BentoGrid.astro';
import { t } from '../i18n/utils';
---

<Layout
  title={t('ru', 'meta.title')}
  description={t('ru', 'meta.description')}
  lang="ru"
  showLangSwitcher={false}
>
  <BentoGrid lang="ru" />
</Layout>

<script>
  const hasRedirected = sessionStorage.getItem('lang-redirected');
  if (!hasRedirected) {
    const browserLang = navigator.language || navigator.languages?.[0] || '';
    const isRussian = browserLang.startsWith('ru');
    sessionStorage.setItem('lang-redirected', '1');
    if (!isRussian) {
      const base = document.querySelector('meta[name="base-url"]')?.getAttribute('content') || '/';
      window.location.replace(base + 'en/');
    }
  }
</script>
