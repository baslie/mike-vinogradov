---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Михаил Виноградов — фотограф, видеомейкер, турист"
  description="Михаил Виноградов — фотограф, видеомейкер, турист. Travel photo, пейзажная фотография, работа с видео."
>
  <!-- ========== BENTO GRID ========== -->
  <main class="p-4 pt-[calc(3.5rem+1rem)] min-h-screen lg:h-dvh">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 lg:grid-rows-3 gap-4 lg:h-full">

      <!-- Tile 1: Avatar + Name -->
      <div
        class="lg:col-span-2 lg:row-span-1 bg-surface rounded-card p-6 md:p-8 flex items-center gap-5 md:gap-6 transition-colors duration-300 animate-fade-in"
        style="animation-delay: 0ms"
      >
        <div class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full bg-bg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&q=80" alt="Михаил Виноградов — фотограф и путешественник" class="w-full h-full object-cover" loading="lazy">
        </div>
        <div>
          <h1 class="font-display text-2xl md:text-3xl lg:text-4xl font-bold text-text leading-tight">Михаил Виноградов</h1>
          <p class="text-text-muted text-sm md:text-base mt-1 font-light">Фотография как часть жизни.</p>
        </div>
      </div>

      <!-- Tile 2: Travel Photo -->
      <div
        class="group lg:col-span-2 lg:row-span-2 md:col-span-2 lg:col-start-3 bg-surface rounded-card relative overflow-hidden min-h-[300px] md:min-h-[200px] transition-colors duration-300 animate-fade-in"
        style="animation-delay: 100ms"
      >
        <!-- Photo -->
        <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=800&h=600&fit=crop&q=80" alt="Горный пейзаж — travel-фотография" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
        <!-- Content -->
        <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 space-y-3">
          <h2 class="font-display text-xl md:text-2xl font-bold text-text">Travel photo</h2>
          <p class="text-sm text-text-muted max-w-md leading-relaxed">Для хороших фотографий можно организовать и небольшую экспедицию. Есть опыт походов, опыт организации походов и разведок. С собой всегда всё необходимое оборудование и снаряжение.</p>
          <a href={`${base}portfolio/#travel-photo`} class="inline-block px-4 py-2 border border-white/20 text-sm text-text rounded-btn hover:bg-white/10 hover:border-white/50 transition-all duration-300">Примеры работ</a>
        </div>
      </div>

      <!-- Tile 3: Landscape Photography -->
      <div
        class="group lg:col-span-1 lg:row-span-2 bg-surface rounded-card relative overflow-hidden min-h-[300px] md:min-h-[200px] transition-colors duration-300 animate-fade-in"
        style="animation-delay: 200ms"
      >
        <!-- Photo -->
        <img src="https://images.unsplash.com/photo-1472214103451-9374bd1c798e?w=500&h=900&fit=crop&q=80" alt="Атмосферный пейзаж — лес и горы Сибири" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
        <!-- Gradient overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
        <!-- Content -->
        <div class="absolute bottom-0 left-0 right-0 p-5 space-y-2">
          <h2 class="font-display text-lg md:text-xl font-bold text-text">Пейзажная фотография</h2>
          <p class="text-xs text-text-muted leading-relaxed">Портрет, репортажная съёмка. Работа на результат, работа с моделями, с поиском необходимых локаций.</p>
          <a href={`${base}portfolio/#other-photos`} class="inline-block px-3 py-1.5 border border-white/20 text-xs text-text rounded-btn hover:bg-white/10 hover:border-white/50 transition-all duration-300">Примеры работ</a>
        </div>
      </div>

      <!-- Tile 4: Video -->
      <div
        class="group lg:col-span-1 lg:row-span-2 bg-surface rounded-card flex flex-col overflow-hidden min-h-[300px] md:min-h-[200px] transition-colors duration-300 animate-fade-in"
        style="animation-delay: 300ms"
      >
        <div class="relative flex-1">
          <img src="https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?w=500&h=600&fit=crop&q=80" alt="Видеосъёмка и кинематограф" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy">
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <svg class="w-16 h-16 text-white/70 group-hover:scale-110 transition-transform duration-500 drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
        <div class="p-5 space-y-2">
          <h2 class="font-display text-lg md:text-xl font-bold text-text">Работа с видео</h2>
          <p class="text-xs text-text-muted leading-relaxed">Съёмка видео. Сценарий. Звук. «Покрасс». Adobe Premier. Motion‑design в After Effects.</p>
          <a href={`${base}portfolio/#video`} class="inline-block px-3 py-1.5 border border-white/20 text-xs text-accent rounded-btn hover:bg-white/10 hover:border-white/50 transition-all duration-300">Примеры работ</a>
        </div>
      </div>

      <!-- Tile 5: Contact -->
      <div
        class="md:col-span-2 lg:col-span-2 lg:row-span-1 rounded-card p-5 md:p-6 flex items-center justify-center gap-3 transition-colors duration-300 animate-fade-in"
        style="animation-delay: 400ms"
      >
        <p class="text-sm text-text-muted font-light">Всегда на связи:</p>
        <a href="https://t.me/siberiawalk" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-text hover:text-accent transition-colors duration-300">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          <span class="text-sm font-medium">Telegram — @siberiawalk</span>
        </a>
      </div>

    </div>
  </main>
</Layout>
