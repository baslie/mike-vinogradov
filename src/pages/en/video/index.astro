---
import Layout from '../../../layouts/Layout.astro';
import VideoGallery from '../../../components/VideoGallery.astro';
import Footer from '../../../components/Footer.astro';
import { t } from '../../../i18n/utils';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const videoIds = [
  'T13ofxbGIFg',
  'UuTDxQoXIfE',
  'm7uV7MZ9wgY',
  'x0FL5NnNx08',
  'TCXIs-VHV90',
  '8LYQSKS6x-Y',
  '1qfpLAmNtCE',
  'lsyI0mGujZg',
];
---

<Layout
  title={t('en', 'video.meta.title')}
  description={t('en', 'video.meta.description')}
  lang="en"
  fullHeight={false}
  pagePath="/video/"
>
  <main class="pt-6 pb-12 px-4 max-w-6xl mx-auto">
    <a
      href={`${base}/en/`}
      class="inline-flex items-center gap-1.5 text-text-muted hover:text-text transition-colors text-sm mb-6"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      {t('en', 'video.back')}
    </a>

    <h1 class="text-3xl font-semibold mb-3">{t('en', 'video.title')}</h1>
    <p class="text-sm text-text-muted mb-8 max-w-xl">{t('en', 'tile4.description')}</p>

    <VideoGallery ids={videoIds} />
  </main>

  <Footer lang="en" />
</Layout>
