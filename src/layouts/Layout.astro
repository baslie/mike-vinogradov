---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  title: string;
  description: string;
  lang?: 'ru' | 'en';
  pagePath?: string;
  fullHeight?: boolean;
  showLangSwitcher?: boolean;
}

const { title, description, lang = 'ru', pagePath = '/', fullHeight = true, showLangSwitcher = true } = Astro.props;
const ruUrl = getRelativeLocaleUrl('ru', pagePath);
const enUrl = getRelativeLocaleUrl('en', pagePath);
const site = Astro.site?.origin ?? '';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
  <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />
  <link rel="alternate" hreflang="ru" href={`${site}${ruUrl}`} />
  <link rel="alternate" hreflang="en" href={`${site}${enUrl}`} />
  <link rel="alternate" hreflang="x-default" href={`${site}${ruUrl}`} />
  <meta name="base-url" content={import.meta.env.BASE_URL} />
</head>
<body class:list={["min-h-screen relative", { "lg:h-dvh lg:overflow-hidden lg:flex lg:flex-col": fullHeight }]}>

  <!-- ========== LANGUAGE SWITCHER ========== -->
  {showLangSwitcher && (
    <div class="lang-switcher absolute top-4 right-4 z-10 flex items-center rounded-full p-0.5" style="background-color: var(--color-switch-pill)">
      <a href={ruUrl} class:list={['lang-btn', { active: lang === 'ru' }]}>RU</a>
      <a href={enUrl} class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
    </div>
  )}

  <slot />

</body>
</html>
