---
import '../styles/global.css';
import { getRelativeLocaleUrl } from 'astro:i18n';

interface Props {
  title: string;
  description: string;
  lang?: 'ru' | 'en';
  pagePath?: string;
  fullHeight?: boolean;
  showLangSwitcher?: boolean;
}

const { title, description, lang = 'ru', pagePath = '/', fullHeight = true, showLangSwitcher = true } = Astro.props;
const ruUrl = getRelativeLocaleUrl('ru', pagePath);
const enUrl = getRelativeLocaleUrl('en', pagePath);
const site = Astro.site?.origin ?? '';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
  <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32x32.png`} />
  <link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16x16.png`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
  <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />
  <link rel="alternate" hreflang="ru" href={`${site}${ruUrl}`} />
  <link rel="alternate" hreflang="en" href={`${site}${enUrl}`} />
  <link rel="alternate" hreflang="x-default" href={`${site}${ruUrl}`} />
  <meta name="base-url" content={import.meta.env.BASE_URL} />
  <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/noto-sans-v38-latin_cyrillic-regular.woff2`} as="font" type="font/woff2" crossorigin />
  <link rel="preload" href={`${import.meta.env.BASE_URL}fonts/noto-sans-v38-latin_cyrillic-700.woff2`} as="font" type="font/woff2" crossorigin />
  <style>
    #page-spinner {
      position: fixed; inset: 0; z-index: 9999;
      display: flex; align-items: center; justify-content: center;
      background: #101010;
      transition: opacity 0.3s ease;
    }
    #page-spinner .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: #a5a5a5; margin: 0 4px;
      animation: dot-pulse 1.2s ease-in-out infinite;
    }
    #page-spinner .dot:nth-child(2) { animation-delay: 0.15s; }
    #page-spinner .dot:nth-child(3) { animation-delay: 0.3s; }
    @keyframes dot-pulse {
      0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
      40% { opacity: 1; transform: scale(1); }
    }
  </style>
</head>
<body class:list={["min-h-screen relative", { "lg:h-dvh lg:overflow-hidden lg:flex lg:flex-col": fullHeight }]}>

  <div id="page-spinner">
    <div class="dot"></div>
    <div class="dot"></div>
    <div class="dot"></div>
  </div>

  <!-- ========== LANGUAGE SWITCHER ========== -->
  {showLangSwitcher && (
    <div class="lang-switcher absolute top-4 right-4 z-10 flex items-center rounded-full p-0.5" style="background-color: var(--color-switch-pill)">
      <a href={ruUrl} class:list={['lang-btn', { active: lang === 'ru' }]}>RU</a>
      <a href={enUrl} class:list={['lang-btn', { active: lang === 'en' }]}>EN</a>
    </div>
  )}

  <slot />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const s = document.getElementById('page-spinner');
      if (s) { s.style.opacity = '0'; setTimeout(() => s.remove(), 300); }
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  </script>

</body>
</html>
